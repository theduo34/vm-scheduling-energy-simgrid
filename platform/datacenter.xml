<?xml version='1.0'?>
<!DOCTYPE platform SYSTEM "https://simgrid.org/simgrid.dtd">
<platform version="4.1">
  <zone id="datacenter" routing="Floyd">

    <!-- ================================================================ -->
    <!-- TYPE A: High Capacity (6 hosts)                                   -->
    <!-- 8 cores @ 2.4 GHz  |  8 GB RAM  |  idle: 120 W  |  peak: 250 W   -->
    <!-- ================================================================ -->
    <host id="hostA1" speed="2.4Gf" core="8">
      <prop id="wattage_per_state" value="120.0:250.0"/>
      <prop id="ram_mb" value="8192"/>
    </host>
    <host id="hostA2" speed="2.4Gf" core="8">
      <prop id="wattage_per_state" value="120.0:250.0"/>
      <prop id="ram_mb" value="8192"/>
    </host>
    <host id="hostA3" speed="2.4Gf" core="8">
      <prop id="wattage_per_state" value="120.0:250.0"/>
      <prop id="ram_mb" value="8192"/>
    </host>
    <host id="hostA4" speed="2.4Gf" core="8">
      <prop id="wattage_per_state" value="120.0:250.0"/>
      <prop id="ram_mb" value="8192"/>
    </host>
    <host id="hostA5" speed="2.4Gf" core="8">
      <prop id="wattage_per_state" value="120.0:250.0"/>
      <prop id="ram_mb" value="8192"/>
    </host>
    <host id="hostA6" speed="2.4Gf" core="8">
      <prop id="wattage_per_state" value="120.0:250.0"/>
      <prop id="ram_mb" value="8192"/>
    </host>

    <!-- ================================================================ -->
    <!-- TYPE B: Medium Capacity (8 hosts)                                 -->
    <!-- 4 cores @ 2.0 GHz  |  4 GB RAM  |  idle: 80 W   |  peak: 170 W   -->
    <!-- ================================================================ -->
    <host id="hostB1" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB2" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB3" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB4" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB5" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB6" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB7" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>
    <host id="hostB8" speed="2.0Gf" core="4">
      <prop id="wattage_per_state" value="80.0:170.0"/>
      <prop id="ram_mb" value="4096"/>
    </host>

    <!-- ================================================================ -->
    <!-- TYPE C: Low Capacity (6 hosts)                                    -->
    <!-- 2 cores @ 1.6 GHz  |  2 GB RAM  |  idle: 50 W   |  peak: 110 W   -->
    <!-- ================================================================ -->
    <host id="hostC1" speed="1.6Gf" core="2">
      <prop id="wattage_per_state" value="50.0:110.0"/>
      <prop id="ram_mb" value="2048"/>
    </host>
    <host id="hostC2" speed="1.6Gf" core="2">
      <prop id="wattage_per_state" value="50.0:110.0"/>
      <prop id="ram_mb" value="2048"/>
    </host>
    <host id="hostC3" speed="1.6Gf" core="2">
      <prop id="wattage_per_state" value="50.0:110.0"/>
      <prop id="ram_mb" value="2048"/>
    </host>
    <host id="hostC4" speed="1.6Gf" core="2">
      <prop id="wattage_per_state" value="50.0:110.0"/>
      <prop id="ram_mb" value="2048"/>
    </host>
    <host id="hostC5" speed="1.6Gf" core="2">
      <prop id="wattage_per_state" value="50.0:110.0"/>
      <prop id="ram_mb" value="2048"/>
    </host>
    <host id="hostC6" speed="1.6Gf" core="2">
      <prop id="wattage_per_state" value="50.0:110.0"/>
      <prop id="ram_mb" value="2048"/>
    </host>

    <!-- ================================================================ -->
    <!-- NETWORK: flat star topology via a central backbone switch         -->
    <!-- Each host-to-switch link: 1 Gbps, 5 ms                           -->
    <!-- => host-to-host: 1 Gbps, 10 ms  (as specified)                   -->
    <!-- Floyd routing computes full table from these 20 edge declarations -->
    <!-- ================================================================ -->
    <router id="backbone_switch"/>

    <link id="link_A1" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_A2" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_A3" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_A4" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_A5" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_A6" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B1" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B2" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B3" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B4" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B5" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B6" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B7" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_B8" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_C1" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_C2" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_C3" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_C4" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_C5" bandwidth="1Gbps" latency="5ms"/>
    <link id="link_C6" bandwidth="1Gbps" latency="5ms"/>

    <route src="hostA1" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_A1"/>
    </route>
    <route src="hostA2" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_A2"/>
    </route>
    <route src="hostA3" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_A3"/>
    </route>
    <route src="hostA4" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_A4"/>
    </route>
    <route src="hostA5" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_A5"/>
    </route>
    <route src="hostA6" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_A6"/>
    </route>
    <route src="hostB1" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B1"/>
    </route>
    <route src="hostB2" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B2"/>
    </route>
    <route src="hostB3" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B3"/>
    </route>
    <route src="hostB4" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B4"/>
    </route>
    <route src="hostB5" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B5"/>
    </route>
    <route src="hostB6" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B6"/>
    </route>
    <route src="hostB7" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B7"/>
    </route>
    <route src="hostB8" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_B8"/>
    </route>
    <route src="hostC1" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_C1"/>
    </route>
    <route src="hostC2" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_C2"/>
    </route>
    <route src="hostC3" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_C3"/>
    </route>
    <route src="hostC4" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_C4"/>
    </route>
    <route src="hostC5" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_C5"/>
    </route>
    <route src="hostC6" dst="backbone_switch" symmetrical="YES">
      <link_ctn id="link_C6"/>
    </route>

  </zone>
</platform>
